OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
# Set to 1 to run without calling OpenAI (deterministic keyword-based fake
# classifier). Useful for offline development/testing of the web form when
# you don't have an API key handy. Do NOT use this for the mentor demo --
# the mission requires real LLM structured output.
MOCK_MODE=0

# PostgreSQL connection string used to persist routed tickets.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ticket_router
